# OpenAI
OPENAI_API_KEY=sk-your-api-key-here

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stt_summary
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stt_summary

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Server
SERVER_PORT=3000
CORS_ORIGIN=http://localhost:8080
# API_KEY=your-api-key-here  # Optional: set to enable API key authentication

# S3 / R2 Storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=stt-uploads
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# OpenAI Model Config
WHISPER_MODEL=whisper-1
GPT_MODEL=gpt-4o
